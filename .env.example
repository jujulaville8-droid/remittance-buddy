# =============================================================
# Remittance Buddy — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.
# =============================================================

# ---- Database (Neon Postgres via Vercel Marketplace) --------
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/remittance_buddy?sslmode=require

# ---- Auth (Clerk — via Vercel Marketplace) ------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---- Cache / Rate limiting (Upstash Redis) ------------------
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ---- File storage (Vercel Blob) -----------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx

# ---- AI Gateway (Vercel — auto-provisioned via vercel env pull) --
# VERCEL_OIDC_TOKEN is injected automatically; no manual API keys needed.

# ---- Payments (Stripe) --------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Remittance (Wise) --------------------------------------
WISE_API_KEY=xxx
WISE_PROFILE_ID=xxx
WISE_WEBHOOK_SECRET=xxx
# Set to "sandbox" for development, "live" for production
WISE_ENV=sandbox

# ---- KYC (Persona) ------------------------------------------
PERSONA_API_KEY=xxx
PERSONA_WEBHOOK_SECRET=xxx
PERSONA_TEMPLATE_ID=xxx

# ---- AML / Fraud (Sardine) ----------------------------------
SARDINE_CLIENT_ID=xxx
SARDINE_SECRET_KEY=xxx
SARDINE_ENV=sandbox

# ---- App -------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
