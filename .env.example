# =============================================================
# My Remittance Pal — Environment Variables (V1 affiliate-only)
# Copy to apps/web/.env.local and fill in values.
# NEVER commit .env.local to version control.
# =============================================================

# ---- Supabase (auth + database) ----
# Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ---- App URL ----
# Used by deep links, share sheet, email CTAs.
# Local dev: http://localhost:3001
# Production: set to your Vercel URL on deploy
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ---- Upstash Redis (optional - caches Wise quotes 60s) ----
# Without these, /api/quotes still works but hits Wise on every request.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Resend (optional - sends rate alert emails) ----
# Without this, the check-alerts cron runs but doesn't deliver emails.
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alerts@myremittancepal.com

# ---- Cron secret (optional - protects cron endpoints) ----
# When set, cron endpoints reject requests without matching Authorization header.
# Vercel Cron automatically adds this header when configured.
CRON_SECRET=
